---
import Base from '../layouts/Base.astro';
import SearchableArticleFeed from '../components/SearchableArticleFeed.astro';
import rawArticles from '../data/articles.json';
import rawVideos from '../data/videos.json';
import { createArticles } from '../lib/articles';
import { createVideos, mergeContent } from '../lib/videos';

const articles = createArticles(rawArticles);
const videos = createVideos(rawVideos);
const allContent = mergeContent(articles, videos);
const currentDate = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Base>
  <SearchableArticleFeed articles={allContent} currentDate={currentDate} />
</Base>
