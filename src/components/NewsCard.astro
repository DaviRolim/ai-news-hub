---
interface Props {
  title: string;
  source: string;
  summary: string;
  url: string;
  publishedAt: string;
  category?: string;
}

const { title, source, summary, url, publishedAt, category = 'General' } = Astro.props;

const date = new Date(publishedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<article class="group border border-gray-800 rounded-lg p-5 hover:border-blue-600 transition-colors bg-gray-900">
  <div class="flex items-center gap-2 mb-2 text-xs text-gray-500">
    <span class="uppercase tracking-wide text-blue-500">{category}</span>
    <span>·</span>
    <span>{source}</span>
    <span>·</span>
    <time datetime={publishedAt}>{date}</time>
  </div>
  <h2 class="text-base font-semibold text-gray-100 group-hover:text-blue-300 transition-colors mb-2 leading-snug">
    <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
  </h2>
  <p class="text-sm text-gray-400 leading-relaxed line-clamp-3">{summary}</p>
</article>
