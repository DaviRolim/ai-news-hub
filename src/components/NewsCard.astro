---
interface Props {
  title: string;
  source: string;
  summary: string;
  url: string;
  publishedAt: string;
  slug: string;
  formattedDate?: string;
  category?: string;
  featured?: boolean;
}

const {
  title,
  source,
  summary,
  url,
  publishedAt,
  slug,
  formattedDate,
  category = 'General',
  featured = false,
} = Astro.props;

const articlePath = `/articles/${slug}/`;
const date = formattedDate ?? new Date(publishedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

{featured ? (
  <article class="border border-gray-700 rounded-xl p-7 bg-gray-900 hover:border-blue-500 transition-colors">
    <div class="flex items-center gap-2 mb-3 text-xs text-gray-500">
      <span class="uppercase tracking-wide text-blue-400 font-semibold">{category}</span>
      <span>·</span>
      <span>{source}</span>
      <span>·</span>
      <time datetime={publishedAt}>{date}</time>
    </div>
    <h2 class="text-2xl font-bold text-white hover:text-blue-300 transition-colors mb-3 leading-snug">
      <a href={articlePath}>{title}</a>
    </h2>
    <p class="text-sm text-gray-300 leading-relaxed line-clamp-4">{summary}</p>
    <div class="mt-4 flex flex-wrap items-center gap-4 text-xs">
      <a href={articlePath} class="text-blue-400 hover:text-blue-300 transition-colors">
        Continue briefing →
      </a>
      <a href={url} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-200 transition-colors">
        Original source
      </a>
    </div>
  </article>
) : (
  <article class="group border border-gray-800 rounded-lg p-5 hover:border-blue-600 transition-colors bg-gray-900 h-full">
    <div class="flex items-center gap-2 mb-2 text-xs text-gray-500">
      <span class="uppercase tracking-wide text-blue-500">{category}</span>
      <span>·</span>
      <span>{source}</span>
      <span>·</span>
      <time datetime={publishedAt}>{date}</time>
    </div>
    <h2 class="text-base font-semibold text-gray-100 group-hover:text-blue-300 transition-colors mb-2 leading-snug">
      <a href={articlePath}>{title}</a>
    </h2>
    <p class="text-sm text-gray-400 leading-relaxed line-clamp-3">{summary}</p>
    <div class="mt-4 flex items-center justify-between gap-3 text-xs">
      <a href={articlePath} class="text-blue-400 hover:text-blue-300 transition-colors">
        Read briefing
      </a>
      <a href={url} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-300 transition-colors">
        Source
      </a>
    </div>
  </article>
)}
